# CallerOS — example environment configuration
# Copy this file to .env and fill in real values.
# The application works with defaults if this file is absent.

# Human-readable application name shown in logs.
CALLER_OS_APP_NAME=CallerOS

# Semantic version of the application.
CALLER_OS_VERSION=1.0.0

# Log verbosity. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
CALLER_OS_LOG_LEVEL=INFO

# Directory where rotating log files are written (relative or absolute path).
CALLER_OS_LOG_DIR=logs

# Deployment environment. One of: development, production, test.
CALLER_OS_ENVIRONMENT=development

# ---------------------------------------------------------------------------
# Stage 3 — Research Worker (AI client)
# ---------------------------------------------------------------------------

# OpenAI secret key (required for ResearchWorker in production).
OPENAI_API_KEY=sk-your-key-here

# OpenAI model to use (defaults to gpt-4o-mini if not set).
OPENAI_MODEL=gpt-4o-mini
